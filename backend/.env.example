PORT=8080

# Supabase connection pooler — Session mode, port 5432 (required for lib/pq prepared statements)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

REDIS_URL=redis://default:pass@host:6379

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://<project-ref>.supabase.co

# Service role key — used for Admin API calls (email update, avatar storage)
# Settings → API → Project API keys → service_role. Keep secret, never expose to frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=https://api.korsana.run/api/strava/callback

# AI Provider API Keys (use either Claude or Gemini)
CLAUDE_API_KEY=sk-ant-your-key
GEMINI_API_KEY=

FRONTEND_URL=https://korsana.run
ALLOWED_ORIGINS=https://korsana.run
ENVIRONMENT=production

# Optional SMTP configuration for notification test sends and live sync-failure alerts
SMTP_HOST=smtp.mailprovider.com
SMTP_PORT=587
SMTP_USERNAME=notifications@korsana.run
SMTP_PASSWORD=super-secret-password
SMTP_FROM_EMAIL=notifications@korsana.run
SMTP_FROM_NAME=Korsana
